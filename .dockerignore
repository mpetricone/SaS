# Version control
.git
.gitignore
.github

# Dev / IDE / AI tooling
.devcontainer
.vscode
.claude
.idea

# Logs, caches, PIDs, sockets
log/*
!log/.keep
tmp/*
!tmp/.keep
tmp/pids/*
!tmp/pids/.keep

# Dependencies (rebuilt in image)
node_modules
vendor/bundle
vendor/cache

# Test + CI
test
coverage
spec

# Local secrets and env files
.env*
config/master.key
config/credentials/*.key

# Local uploads / build artefacts (regenerated in image)
storage/*
!storage/.keep
public/assets
app/assets/builds/*
!app/assets/builds/.keep

# Editor / OS noise
*.swp
*.swo
.DS_Store

# Stray lockfile copies
Gemfile.lock.newer
