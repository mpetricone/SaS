# Copy to .env.production and fill in real values. Do NOT commit the populated file.

# Git repository to clone when building the app image.
# GIT_PASSWORD accepts a personal access token (PAT) or account password.
GIT_REPO_URL=git@github.com:mpetricone/SaS.git
GIT_BRANCH=master
# Absolute path on the host to the SSH private key used to clone the repo.
GIT_SSH_KEY_PATH=/root/.ssh/id_rsa

# Rails secret. Generate with:  bundle exec rails secret
# (or: openssl rand -hex 64)
SECRET_KEY_BASE=replace_me_with_a_real_secret

# Database credentials.
#   MYSQL_ROOT_PASSWORD is only used by the MariaDB container for its root user.
#   MYSQL_USER / MYSQL_PASSWORD are what the Rails app logs in with.
MYSQL_ROOT_PASSWORD=replace_me_root_pw
MYSQL_USER=sas
MYSQL_PASSWORD=replace_me_app_pw

# Host path for Active Storage uploads (your SMB mount point on this host).
# Bind-mounted into the app container at /rails/storage.
SAS_STORAGE_PATH=/mnt/smb/sas_storage

# Hostname used in mailer-generated URLs (invoice links, etc.).
APP_HOST=sas.example.lan
APP_PROTOCOL=http

# SMTP relay. Leave SMTP_USER_NAME/SMTP_PASSWORD blank for anonymous relays.
SMTP_ADDRESS=smtp.example.lan
SMTP_PORT=587
SMTP_DOMAIN=example.lan
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
